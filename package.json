{
  "name": "@bitwild/nest-puppeteer",
  "version": "0.0.8",
  "description": "Puppeteer (Headless Chrome) provider for NestJS with Cloudflare Browser Rendering-style API",
  "keywords": [
    "browser",
    "headless",
    "nest",
    "nestjs",
    "provider",
    "puppeteer",
    "pdf",
    "screenshot",
    "scrape"
  ],
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "@nestjs/swagger": ">=7",
    "class-transformer": ">=0.5",
    "class-validator": ">=0.14",
    "puppeteer": ">=22"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    },
    "@nestjs/swagger": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.15.24",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "puppeteer": "^24.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
