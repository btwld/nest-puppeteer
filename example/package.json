{
  "name": "nestjs-puppeteer-example",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "start": "npx ts-node -r reflect-metadata src/main.ts",
    "start:dev": "npx ts-node-dev -r reflect-metadata src/main.ts",
    "build": "tsc --noEmit",
    "test": "jest --config jest.config.json",
    "test:e2e": "jest --config jest.config.json --testPathPattern e2e"
  },
  "dependencies": {
    "@bitwild/nest-puppeteer": "^0.0.6",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "puppeteer": "^24.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/testing": "^11.0.0",
    "@swc/core": "^1.15.0",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "typescript": "^5.8.0"
  }
}
